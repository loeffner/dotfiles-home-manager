-static void submit_password(struct swaylock_state *state) {
+void submit_password(struct swaylock_state *state) {
 	if (state->args.ignore_empty && state->password.len == 0) {
 		return;
 	}
 
+	if (state->auto_submit_timer) {
+		loop_remove_timer(state->eventloop, state->auto_submit_timer);
+		state->auto_submit_timer = NULL;
+	}
+
 	state->auth_state = AUTH_STATE_VALIDATING;
 
-	if (!write_comm_request(&state->password)) {
+	if (state->comm_busy) {
+		// An auto-submit attempt is in flight. Queue this submission; the
+		// reply handler (comm_in) re-submits the current buffer when the
+		// in-flight attempt fails.
+		state->enter_pending = true;
+		damage_state(state);
+		return;
+	}
+
+	state->comm_busy = true;
+	if (!write_comm_request(&state->password, true)) {
+		state->comm_busy = false;
 		state->auth_state = AUTH_STATE_INVALID;
 		schedule_indicator_clear(state);
 	}
@@ -93,6 +109,40 @@
 	damage_state(state);
 }
 
+static void auto_submit(void *data) {
+	struct swaylock_state *state = data;
+	state->auto_submit_timer = NULL;
+	if (state->password.len == 0 ||
+			state->auth_state == AUTH_STATE_VALIDATING) {
+		return;
+	}
+	if (state->comm_busy) {
+		// Previous attempt still in flight; retry shortly.
+		state->auto_submit_timer = loop_add_timer(
+				state->eventloop, 50, auto_submit, state);
+		return;
+	}
+	// Silently try the current buffer: keep it on failure (no red flash, no
+	// failed-attempts counter) so typing simply continues.
+	state->auto_attempt = true;
+	state->comm_busy = true;
+	if (!write_comm_request(&state->password, false)) {
+		state->comm_busy = false;
+		state->auto_attempt = false;
+	}
+}
+
+static void schedule_auto_submit(struct swaylock_state *state) {
+	if (state->args.auto_submit_delay == 0) {
+		return;
+	}
+	if (state->auto_submit_timer) {
+		loop_remove_timer(state->eventloop, state->auto_submit_timer);
+	}
+	state->auto_submit_timer = loop_add_timer(state->eventloop,
+			state->args.auto_submit_delay, auto_submit, state);
+}
