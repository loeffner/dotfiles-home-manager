ortenv() {
  [[ -n "$HALCONROOT" ]] && echo "HALCONROOT=$HALCONROOT" || echo "No \$HALCONROOT set."
  [[ -n "$HALCON_AI2_PATH" ]] && echo "HALCON_AI2_PATH=$HALCON_AI2_PATH" || echo "No \$HALCON_AI2_PATH set."
  [[ -n "$ADSP_LIBRARY_PATH" ]] && echo "ADSP_LIBRARY_PATH=$ADSP_LIBRARY_PATH" || echo "No \$ADSP_LIBRARY_PATH set."
  [[ -n "$LD_LIBRARY_PATH" ]] && echo "LD_LIBRARY_PATH=$LD_LIBRARY_PATH" || echo "No \$LD_LIBRARY_PATH set."

  # Try to cat the soc_id, but ignore errors if the file doesn't exist (e.g., on non-ARM platforms)
  cat /sys/devices/soc0/soc_id 2>/dev/null || echo "No soc_id found."
}

hailoenv() {
  [[ -n "$HALCONROOT" ]] && echo "HALCONROOT=$HALCONROOT" || echo "No \$HALCONROOT set."
  [[ -n "$HALCON_AI2_PATH" ]] && echo "HALCON_AI2_PATH=$HALCON_AI2_PATH" || echo "No \$HALCON_AI2_PATH set."
  [[ -n "$HAILO_VIRTUAL_ENV" ]] && echo "HAILO_VIRTUAL_ENV=$HAILO_VIRTUAL_ENV" || echo "No \$HAILO_VIRTUAL_ENV set."
  [[ -n "$LD_LIBRARY_PATH" ]] && echo "LD_LIBRARY_PATH=$LD_LIBRARY_PATH" || echo "No \$LD_LIBRARY_PATH set."

  apt list hailort
  hailortcli fw-control identify
}


