ai2() {
  if [[ -z "$1" ]]; then
    local LATEST_AI2_PATH=$HNIGHTLY"/lib/x64-linux"
    export HALCON_AI2_PATH=$LATEST_AI2_PATH
  elif [[ "$1" == '-d' ]]; then
