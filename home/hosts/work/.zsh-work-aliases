himpact_branch() {
  # An array, because zsh doesn't word-split an unquoted scalar — a single
  # "--git X...HEAD" string would reach himpact.py as one argument.
  local -a GIT
  if [[ -n $1 ]]; then
    GIT=(--git "$1...HEAD")
  fi
  echo "$___HIMPACT_DIR"/himpact.py --db /halcon/himpact/himpact.sqlite3 query "${GIT[@]}" --exclude-priority-list
  "$___HIMPACT_DIR"/himpact.py --db /halcon/himpact/himpact.sqlite3 query "${GIT[@]}" --exclude-priority-list
}

hmake_print() {
  local GREEN='\033[1;32m'
  local YELLOW='\033[1;33m'
  local BLUE='\033[1;34m'
  local NC='\033[0m'

  echo "${GREEN}HMAKE Configuration:${NC}"
  printf "${BLUE}%-20s${NC} : ${YELLOW}%s${NC}\n" "ARCH" "$HMAKE_ARCH"
  printf "${BLUE}%-20s${NC} : ${YELLOW}%s${NC}\n" "MODE" "$HMAKE_MODE"
  printf "${BLUE}%-20s${NC} : ${YELLOW}%s${NC}\n" "TARGET" "$HMAKE_TARGET"
  printf "${BLUE}%-20s${NC} : ${YELLOW}%s${NC}\n" "ARCHDIR" "$HMAKE_ARCHDIR"
  printf "${BLUE}%-20s${NC} : ${YELLOW}%s${NC}\n" "FLAGS" "$HMAKE_FLAGS"
}

hmake_master() {
  export HMAKE_ARCH="x64-linux-clang21_1"
  export HMAKE_MODE="debug"
  export HMAKE_TARGET_ALL=" "
  export HMAKE_TARGET_COMPACT="hlib hdl hodor hrun hdevelop"
  export HMAKE_TARGET="$HMAKE_TARGET_COMPACT"
  export HMAKE_ARCHDIR="$HOME/halcon/current/build/master"
  export HMAKE_FLAGS="-DWITH_DL_GRAPH_API_INTERNAL"
  export HMAKE_ARGS="--arch $HMAKE_ARCH --$HMAKE_MODE --target $HMAKE_TARGET --archdir $HMAKE_ARCHDIR $HMAKE_FLAGS --thirdparty-libs /opt/home/buildbot/halcon/thirdparty --thirdparty-tools /opt/home/buildbot/halcon/thirdparty/tools"
  hmake_print
}

hmake_release() {
  export HMAKE_ARCH="x64-linux-icx-latest"
  export HMAKE_MODE="release"
  export HMAKE_TARGET_ALL=" "
  export HMAKE_TARGET_COMPACT="hlib hdl hodor hrun hdevelop"
  export HMAKE_TARGET="$HMAKE_TARGET_COMPACT"
  export HMAKE_ARCHDIR="$HOME/halcon/current/build/release"
  export HMAKE_FLAGS=""
  export HMAKE_ARGS="--arch $HMAKE_ARCH --$HMAKE_MODE --target $HMAKE_TARGET --archdir $HMAKE_ARCHDIR $HMAKE_FLAGS --thirdparty-libs /opt/home/buildbot/halcon/thirdparty --thirdparty-tools /opt/home/buildbot/halcon/thirdparty/tools"
  hmake_print
}

hmake_build() {
  $HOME/halcon/current/tools/build/hmake.pl --arch "$HMAKE_ARCH" --"$HMAKE_MODE" --target "$HMAKE_TARGET" --archdir "$HMAKE_ARCHDIR" "$HMAKE_FLAGS" --thirdparty-libs /opt/home/buildbot/halcon/thirdparty --thirdparty-tools /opt/home/buildbot/halcon/thirdparty/tools
