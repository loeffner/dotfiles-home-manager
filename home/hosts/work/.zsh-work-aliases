###############################################################################
# Special builds (asan, msan, ubsan)
###############################################################################

__check_default_build_dir() {
  local ASAN_BUILD_DIR="$1"
  if [[ "$ASAN_BUILD_DIR" != /* ]] && [[ "$ASAN_BUILD_DIR" != ~/* ]]; then
    if [[ "$ASAN_BUILD_DIR" =~ .*build/.* ]]; then
      ASAN_BUILD_DIR=$(echo "$ASAN_BUILD_DIR" | sed "s|.*build/|$HOME/halcon/current/build/|")
    else
      log_warning "The path seems to be a relative path not related to the build directory:"
      echo $ASAN_BUILD_DIR
      echo
      read "confirmation?Do you wish to continue? [y/N]: "
      case "$confirmation" in
      [Yy]*)
        ;;
      *)
        log_info "Operation cancelled by user."
        return 1
        ;;
      esac
    fi
  fi
}

asan_build() {
  local ASAN_BUILD_DIR="$1"
  __check_default_build_dir "$ASAN_BUILD_DIR" || return 1

  $HOME/halcon/current/tools/build/hmake.pl --arch x64-linux-clang21_1 --debug --archdir $ASAN_BUILD_DIR -DWITH_ADDRESS_SANITIZER
  asan_setup "$ASAN_BUILD_DIR"
}

asan_setup() {
  local ASAN_BUILD_DIR="$1"
  __check_default_build_dir "$ASAN_BUILD_DIR" || return 1

  export ASAN_SYMBOLIZER_PATH=/halcon/toolchains/x64-linux/clang-21.1.4/bin/llvm-symbolizer
  export LSAN_OPTIONS=suppressions=$HALCON_SOURCE_DIR/tools/ci/asan_leak_suppr.txt:print_suppressions=0
  export ASAN_OPTIONS=detect_leaks=1
  sethalcon "$ASAN_BUILD_DIR"
}

asan_disable() {
  export ASAN_OPTIONS=detect_leaks=0
  echo ASAN_OPTIONS=$ASAN_OPTIONS
}

asan_reset() {
  unset ASAN_OPTIONS
  echo ASAN_OPTIONS=$ASAN_OPTIONS
}

asan_cuda() {
  export ASAN_OPTIONS=protect_shadow_gap=0:replace_intrin=0
  echo ASAN_OPTIONS=$ASAN_OPTIONS
}

msan_build() {
  local MSAN_BUILD_DIR="$1"
  __check_default_build_dir "$MSAN_BUILD_DIR" || return 1

  $HOME/halcon/current/tools/build/hmake.pl --arch x64-linux-clang21_1_msan --target hrun --tuning --archdir $MSAN_BUILD_DIR
  msan_setup $MSAN_BUILD_DIR
}

msan_setup() {
  local MSAN_BUILD_DIR="$1"
  __check_default_build_dir "$MSAN_BUILD_DIR" || return 1

  export XLOCALEDIR=/usr/share/X11/locale
  export LD_LIBRARY_PATH=/halcon/thirdparty/tools/msan/lib/:${LD_LIBRARY_PATH}
  export MSAN_SYMBOLIZER_PATH=/halcon/toolchains/x64-linux/clang-21.1.4/bin/llvm-symbolizer
  sethalcon "$MSAN_BUILD_DIR"
}

ubsan_build() {
  local UBSAN_BUILD_DIR="$1"
  __check_default_build_dir "$UBSAN_BUILD_DIR" || return 1

  $HOME/halcon/current/tools/build/hmake.pl --arch x64-linux-clang21_1_usan --tuning --archdir $UBSAN_BUILD_DIR
  ubsan_setup "$UBSAN_BUILD_DIR"
}

ubsan_setup() {
  local UBSAN_BUILD_DIR="$1"
  __check_default_build_dir "$UBSAN_BUILD_DIR" || return 1

  export PATH=/halcon/toolchains/x64-linux/clang-19.1.0/bin/:$PATH
  export UBSAN_OPTIONS=print_stacktrace=1
  sethalcon "$UBSAN_BUILD_DIR"
}


