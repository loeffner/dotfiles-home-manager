hdx() {
  if [[ -z "$DISPLAY" ]]; then
    dx2go || return 1
  fi
  if [[ -z "$HALCONROOT" ]]; then
    nightly >/dev/null || return 1
  fi
  if [[ -z "$HALCON_AI2_PATH" ]]; then
    ai2 /home/loesela/halcon/qualcomm/build/x64-linux-debug/install/libd/x64-linux >/dev/null || return 1
  fi

  echo HALCONROOT: "$HALCONROOT"
  echo HALCON_AI2_PATH: "$HALCON_AI2_PATH"
  echo LICENSE: "$(ls "$HALCONROOT"/license)"
  echo DISPLAY: "$DISPLAY"

  hdevelop "$@"
}

alias hrun="hrun -p $HOME/halcon/current/tests/templates/procedures/"
alias hodor="hodor -p $HOME/halcon/current/tests/templates/procedures/"
alias hodor_slow="hodor -p $HOME/halcon/current/tests/templates/procedures/ --slow-tests"
alias hodor_repeat="hodor --loop-last-test --no-dispatch -p $HOME/halcon/current/tests/templates/procedures/"
alias hodor_mem="hodor -p $HOME/halcon/current/tests/templates/procedures/ -n 1 --num-aop-threads 4 --peak-memory"

hlibu() {
  hlib_unittests --gtest_filter=*$1*
}
hdlu() {
  hdl_unittests --gtest_filter=*$1*
}
door() {
  hodor --autotests --problem-reports --filter=.*$1.*
}

lic() {
  if [[ $HOST != "buteo2" ]]; then
    log_error "The available licenses are only available on buteo2."
    return 1
  fi
  if [[ -z "$1" || $1 == "professional" ]]; then
    local license="license_dl_professional.dat"
  elif [[ $1 == "enhanced" ]]; then
    local license="license_dl_enhanced.dat"
  elif [[ $1 == "floating" ]]; then
    local license="license_floating.dat"
  elif [[ $1 == "no_dl" ]]; then
    local license="license_no_dl.dat"
  elif [[ $1 == "fi" ]]; then
    local license="license_progress_fi.dat"
  else
    log_error "Invalid license type. Please specify 'enhanced' or 'professional'."
    return 1
  fi

  if [[ -d "$HOME/halcon/current/build/master/license" ]]; then
    rm -f "$HOME/halcon/current/build/master/license/"*
  fi

  cp "$HOME/halcon/current/license/$license" "$HOME/halcon/current/build/master/license/"
  log_success "Set the license of build/master to '$license'."
}

_lic() {
  compadd enhanced professional floating no_dl fi
}
