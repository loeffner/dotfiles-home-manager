set-ortenv() {
  master
  export HALCON_AI2_PATH="/home/loesela/halcon/qualcomm/build/x64-linux-debug/install/libd/x64-linux"
  export ADSP_LIBRARY_PATH=""
  export LD_LIBRARY_PATH="/home/loesela/halcon/qualcomm/build/x64-linux-debug/install/libd/x64-linux/thirdparty/onnxruntime"
