###############################################################################
# /public/tmp
###############################################################################

cptmp() {
  local DESTINATION="/public/tmp/alo"

  if [[ ! -d $DESTINATION ]]; then
    mkdir -p $DESTINATION
  fi

  if [[ $# -eq 0 ]]; then
    log_error "Usage: cptmp <source> [cp_options]"
    return 1
  fi

  local SOURCE="$1"
  shift

  if [[ -e "$SOURCE" ]]; then
    cp -r "$@" "$SOURCE" "$DESTINATION"
  else
    log_error "$SOURCE does not exist."
    return 1
  fi

  chmodtmp
}

chmodtmp() {
  chmod -R g+rw /public/tmp/alo
}

alias cleantmp="rm -r /public/tmp/alo"


###############################################################################
# Documentation
###############################################################################

_DOC_OP_BASE="$HOME/halcon/current/build/master"
_DOC_OP_EN_DIR="$_DOC_OP_BASE/doc_en_US/html/reference/operators"

typeset -ga _DOC_OPS_CACHE=()
_DOC_OPS_CACHE_MTIME=""

_doc_operator_build_cache() {
  local dir="$_DOC_OP_EN_DIR"
  [[ -d "$dir" ]] || { _DOC_OPS_CACHE=(); _DOC_OPS_CACHE_MTIME=""; return; }

  local mtime
  mtime="$(stat -c %Y "$dir" 2>/dev/null || echo "")"

  if (( ${#_DOC_OPS_CACHE[@]} == 0 )) || [[ "$mtime" != "$_DOC_OPS_CACHE_MTIME" ]]; then
    setopt local_options NULL_GLOB
    _DOC_OPS_CACHE=()
    local f name
    for f in "$dir"/*.html; do
      name="${f:t:r}"
      _DOC_OPS_CACHE+=("$name")
    done
    _DOC_OPS_CACHE_MTIME="$mtime"
  fi
}

doc_operator() {
  if [[ "$1" == "--refresh-cache" ]]; then
    _DOC_OPS_CACHE=()
    _DOC_OPS_CACHE_MTIME=""
    _doc_operator_build_cache
    log_success "doc_operator: cache refreshed (${#_DOC_OPS_CACHE[@]} operators)."
    return 0
  fi

  local op="$1"
  local lang="${2:-en}"

  if [[ -z "$op" ]]; then
    log_error "Usage: doc_operator <OPERATOR_NAME> [de|en|jp|ja]"
    return 2
  fi

  local locale
  case "$lang" in
    en) locale="en_US" ;;
    de) locale="de_DE" ;;
    jp|ja) locale="ja_JP" ;;
    *)
      log_error "Unsupported language: $lang (use: de, en, jp/ja)"
      return 2
      ;;
  esac

  local dir="$_DOC_OP_BASE/doc_${locale}/html/reference/operators"
  local file="${dir}/${op}.html"

  if [[ ! -f "$file" ]]; then
    log_error "Not found: $file"
    return 1
  fi

  command -v code >/dev/null 2>&1 || { log_error "VS Code 'code' CLI not found."; return 127; }
  code "$file"
}

doc_operator_ops() {
  _doc_operator_build_cache
  printf '%s\n' "${_DOC_OPS_CACHE[@]}"
}

_doc_operator_completion() {
  if (( CURRENT == 3 )); then
    compadd de en jp ja
    return
  fi

  _doc_operator_build_cache
  if (( ${#_DOC_OPS_CACHE[@]} )); then
    compadd "${_DOC_OPS_CACHE[@]}"
  fi
}
compdef _doc_operator_completion doc_operator
compdef _doc_operator_completion doc_operator_ops


