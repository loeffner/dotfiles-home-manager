hvenv() {
  cd ~ || return
  vact hvenv
  cd -
}

_setup_conda() {
  local CONDA_DIR=$1
  local __conda_setup
  __conda_setup="$("$CONDA_DIR" 'shell.zsh' 'hook' 2>/dev/null)"
  if [[ $? -eq 0 ]]; then
    eval "$__conda_setup"
  else
    if [[ -f "$CONDA_DIR/etc/profile.d/conda.sh" ]]; then
      . "$CONDA_DIR/etc/profile.d/conda.sh"
    else
      export PATH="$CONDA_DIR/bin:$PATH"
    fi
  fi
  unset __conda_setup
}

use_miniconda3() {
  case $HOST in
  buteo2)
    _setup_conda "$HOME"/miniforge3
    ;;
  *)
    log_warning "Miniconda is not yet installed on this host"
    ;;
  esac
}

use_ort() {
  use_miniconda3
  conda activate ort
}

dlhython_activate() {
  local current_host=$HOST
  local dir="$HOME/proj/deep-learning-with-hython"
  local env_path="${dir}/dl-hython-${current_host}"

  if [[ ! -d "${env_path}" ]]; then
    echo "${env_path}"
    log_warning "Directory for the current host (${current_host}) does not exist!"
    return
  fi

  if [[ -f "${env_path}/bin/activate" ]]; then
    source "${env_path}/bin/activate"
  else
    log_warning "Activate script not found for the current host (${current_host})!"
  fi

  master
  mvtec_bash_add_python_path_entry $dir/source
  echo "halcon package is version:"
  pip list | grep mvtec-halcon
}

dlhython_create() {
  local current_host=$HOST
  local dir="$HOME/proj/deep-learning-with-hython"
  local env_path="${dir}/dl-hython-${current_host}"

  if [[ -d "${env_path}" ]]; then
    log_warning "Directory for the current host (${current_host}) already exists!"
    return
  fi

  python3 -m venv "${env_path}"

  if [[ -f "${env_path}/bin/activate" ]]; then
    source "${env_path}/bin/activate"

    [[ -f "requirements.txt" ]] && pip install -r requirements.txt || log_warning "requirements.txt not found!"
    [[ -f "requirements_tools.txt" ]] && pip install -r requirements_tools.txt || log_warning "requirements_tools.txt not found!"

    local whl="$HOME/halcon/current/build/master/bind/python/generated/dist/mvtec_halcon-26050.0.0-py3-none-any.whl"
    [[ -f "$whl" ]] && pip install "$whl" || log_warning "halcon python package not found!"
  else
    log_error "Unable to activate the virtual environment. Activation script not found!"
  fi
}

dlhython_deactivate() {
  deactivate
}


