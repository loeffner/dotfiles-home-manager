#!/bin/zsh

###############################################################################
# logging
###############################################################################

log_success() { print -P "%F{green}✓%f $*"; }
log_warning() { print -P "%F{yellow}⚠%f $*" >&2; }
log_error()   { print -P "%F{red}✗%f $*" >&2; }

###############################################################################
# ls, grep, rsync and find
###############################################################################

alias ll='ls -alhF'
alias la='ls -A'
alias l='ls -CF'

if command -v dircolors &>/dev/null; then
  test -r "$HOME"/.dircolors && eval "$(dircolors -b "$HOME"/.dircolors)" || eval "$(dircolors -b)"
  alias ls='ls --color=auto'
  alias vdir='vdir --color=auto'
  alias grep='grep --color=auto'
  alias fgrep='fgrep --color=auto'
  alias egrep='egrep --color=auto'
fi

alias rsync_update='rsync -a --info=progress2 --delete'
alias rsync_copy='rsync -a --info=progress2'

alias untargz="tar -xvzf"
alias untarxz="tar -xvf"

###############################################################################
# pathways and shortcuts
###############################################################################

alias q="exit"
alias c="clear"
alias rawzsh="ZELLIJ=0 zsh"

export CONFIG_HOME="$HOME/.config"
alias zshrc="source $HOME/.zshrc"

alias brc="code $HOME/.zshrc"
alias bls="code $HOME/.zsh-aliases"
alias bdx="code $HOME/.bash_display"
alias gconf="code $HOME/.gitconfig"

cf() {
  local pattern=$1
  code $(find . -type f -iname "$pattern")
}

###############################################################################
# Editors
# ###############################################################################

alias code="code-insiders"
alias v="vim ."

###############################################################################
# Home Manager
###############################################################################

hms() {
  local target="${1:-work-$(uname -m)-linux}"
  home-manager switch --flake "git+file://$HOME/dotfiles#${target}"
}


###############################################################################
# Python Environments
###############################################################################

vact() {
  local dir
  if [[ -z $1 ]]; then
    dir='.'
  else
    dir="$1"
  fi
  source "$dir/bin/activate"
}

###############################################################################
# ssh
###############################################################################

pf() {
  if [[ $# -lt 2 || $# -gt 4 ]]; then
    echo "Usage: pf <ssh-host> <remote-port> [local-port] [remote-host]"
    echo
    echo "Examples:"
    echo "  pf locean 8482"
    echo "  pf loeffner@192.168.178.101 8482 9999"
    echo "  pf myserver 5432 15432 db.internal"
    return 1
  fi

  local ssh_host="$1"
  local remote_port="$2"
  local local_port="${3:-$remote_port}"
  local remote_host="${4:-127.0.0.1}"

  echo "Forwarding localhost:${local_port} -> ${remote_host}:${remote_port} via ${ssh_host}"
  ssh -L "${local_port}:${remote_host}:${remote_port}" "$ssh_host"
}

waitfor() {
  local host=$1
  local first_check=true

  while ! ping -c 1 -W 1 "$host" >/dev/null 2>&1; do
    if $first_check; then
      echo -n "Waiting for workstation ($host)"
      first_check=false
    fi
    echo -n "."
    sleep 2
  done

  log_success "Workstation ($host) is available!"
}

_waitfor() {
  local hosts=(${(f)"$(awk '{print $1}' ~/.ssh/known_hosts 2>/dev/null | cut -d',' -f1 | sort -u)"})
  compadd -a hosts
}
compdef _waitfor waitfor
